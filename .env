# ====================================================
# Phase 6 — Real AI Threat Analysis (all optional)
# Leave any of these unset and the app falls back to the
# deterministic rule-based engine automatically — nothing breaks.
# ====================================================

# Primary chain — Groq's free tier hosts Llama 3.2, Gemma 2/3, DeepSeek-R1, Qwen 2.5
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Secondary cloud fallback — free tier at https://aistudio.google.com
GEMINI_API_KEY=

# Local fallback — only used if you have Ollama running locally (no key needed)
# Install: https://ollama.com  then `ollama pull phi4-mini` (or llama3.2 / qwen2.5)
OLLAMA_HOST=http://localhost:11434
